# ── Assemble HTML ──────────────────────────────────────────────────────────────

if not args.no_html:
    def to_div(fig):
        return fig.to_html(full_html=False, include_plotlyjs=False,
                           config={"displayModeBar": False, "responsive": True})

    HTML = f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Godot Engine · PR Analytics</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{{box-sizing:border-box;margin:0;padding:0}}
    :root{{
      --bg:#0d1117;--card:#161b22;--border:#30363d;
      --blue:#478CBF;--green:#3FB950;--orange:#FF8C42;
      --red:#F85149;--purple:#BC8CFF;--yellow:#E3B341;--cyan:#79C0FF;
      --text:#e6edf3;--muted:#8b949e;
    }}
    body{{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;line-height:1.6}}

    /* ── Header ── */
    .page-header{{
      background:linear-gradient(135deg,#0d1117 0%,#1a2744 50%,#0d1117 100%);
      border-bottom:1px solid var(--border);
      padding:52px 56px 44px;
      position:relative;overflow:hidden;
    }}
    .page-header::before{{
      content:'';position:absolute;top:-60%;left:-15%;
      width:700px;height:700px;
      background:radial-gradient(circle,rgba(71,140,191,.13) 0%,transparent 65%);
      pointer-events:none;
    }}
    .page-header::after{{
      content:'';position:absolute;bottom:-40%;right:-10%;
      width:500px;height:500px;
      background:radial-gradient(circle,rgba(188,140,255,.08) 0%,transparent 65%);
      pointer-events:none;
    }}
    .header-eyebrow{{font-size:11px;font-weight:700;letter-spacing:.18em;
      text-transform:uppercase;color:var(--blue);margin-bottom:10px}}
    .page-header h1{{font-size:42px;font-weight:700;letter-spacing:-.8px;
      margin-bottom:10px;color:var(--text)}}
    .page-header h1 span{{color:var(--blue)}}
    .header-sub{{color:var(--muted);font-size:15px;max-width:580px;line-height:1.7}}

    /* ── KPI Strip ── */
    .kpi-strip{{display:grid;grid-template-columns:repeat(4,1fr);
      gap:1px;background:var(--border);border-bottom:1px solid var(--border)}}
    .kpi{{background:var(--card);padding:30px 36px;position:relative}}
    .kpi::after{{content:'';position:absolute;bottom:0;left:36px;right:36px;
      height:3px;border-radius:3px 3px 0 0}}
    .kpi.blue::after{{background:var(--blue)}}
    .kpi.green::after{{background:var(--green)}}
    .kpi.orange::after{{background:var(--orange)}}
    .kpi.purple::after{{background:var(--purple)}}
    .kpi-label{{font-size:11px;font-weight:700;letter-spacing:.1em;
      text-transform:uppercase;color:var(--muted);margin-bottom:10px}}
    .kpi-value{{font-size:40px;font-weight:700;letter-spacing:-1.5px;
      color:var(--text);line-height:1}}
    .kpi-sub{{font-size:12px;color:var(--muted);margin-top:8px}}

    /* ── Content ── */
    .content{{max-width:1440px;margin:0 auto;padding:0 40px 96px}}
    .section{{margin-top:64px}}
    .section-header{{display:flex;align-items:baseline;gap:14px;margin-bottom:6px}}
    .section-num{{font-size:11px;font-weight:700;letter-spacing:.18em;
      text-transform:uppercase;color:var(--blue);min-width:36px}}
    .section-title{{font-size:23px;font-weight:600;letter-spacing:-.3px;color:var(--text)}}
    .section-desc{{font-size:14px;color:var(--muted);margin:6px 0 20px 50px;
      max-width:700px;line-height:1.75}}

    /* ── Chart Card ── */
    .chart-card{{background:var(--card);border:1px solid var(--border);
      border-radius:12px;padding:8px;overflow:hidden}}

    /* ── Insight Pills ── */
    .insights{{display:flex;gap:14px;margin-bottom:18px;flex-wrap:wrap}}
    .insight{{background:var(--card);border:1px solid var(--border);
      border-left:3px solid var(--blue);border-radius:8px;
      padding:12px 18px;font-size:13px;color:var(--muted);flex:1;min-width:200px}}
    .insight strong{{color:var(--text)}}
    .insight.green{{border-left-color:var(--green)}}
    .insight.orange{{border-left-color:var(--orange)}}
    .insight.red{{border-left-color:var(--red)}}
    .insight.purple{{border-left-color:var(--purple)}}

    /* ── Grid Layouts ── */
    .grid-2{{display:grid;grid-template-columns:1fr 1fr;gap:20px}}
    .grid-big-small{{display:grid;grid-template-columns:3fr 2fr;gap:20px}}

    footer{{border-top:1px solid var(--border);text-align:center;
      padding:28px;font-size:12px;color:var(--muted)}}

    @media(max-width:1000px){{
      .kpi-strip{{grid-template-columns:repeat(2,1fr)}}
      .grid-2,.grid-big-small{{grid-template-columns:1fr}}
      .page-header{{padding:36px 24px 32px}}
      .content{{padding:0 20px 64px}}
    }}
  </style>
</head>
<body>

<!-- ── Header ─────────────────────────────────────────────────────────────── -->
<header class="page-header">
  <div class="header-eyebrow">Godot Engine · Open Source · GitHub</div>
  <h1>Pull Request <span>Analytics</span></h1>
  <p class="header-sub">
    {YEARS_SPAN} years of community contributions examined — from the first PR in
    {FIRST_PR_YEAR} through {date.today().strftime("%B %Y")}.
    Every merge, every review, every reaction.
  </p>
</header>

<!-- ── KPI Strip ──────────────────────────────────────────────────────────── -->
<div class="kpi-strip">
  <div class="kpi blue">
    <div class="kpi-label">Total Pull Requests</div>
    <div class="kpi-value">{TOTAL_PRS:,}</div>
    <div class="kpi-sub">Across {YEARS_SPAN} years of development</div>
  </div>
  <div class="kpi green">
    <div class="kpi-label">Merge Rate</div>
    <div class="kpi-value">{MERGE_RATE}</div>
    <div class="kpi-sub">{MERGED:,} PRs successfully merged</div>
  </div>
  <div class="kpi orange">
    <div class="kpi-label">Median Time to Merge</div>
    <div class="kpi-value">{MEDIAN_TTM} days</div>
    <div class="kpi-sub">Mean is {MEAN_TTM} days — a heavy long tail</div>
  </div>
  <div class="kpi purple">
    <div class="kpi-label">Open PRs Today</div>
    <div class="kpi-value">{OPEN_PRS:,}</div>
    <div class="kpi-sub">Some submitted as far back as {oldest_yr}</div>
  </div>
</div>

<!-- ── Content ────────────────────────────────────────────────────────────── -->
<div class="content">

  <section class="section">
    <div class="section-header"><span class="section-num">01</span>
      <span class="section-title">{YEARS_SPAN} Years of Godot</span></div>
    <p class="section-desc">
      From a modest 326 PRs in {FIRST_PR_YEAR} to over 7,000 per year by 2024. The 2020–2022 surge
      reflects Godot 4.0 development, while 2022–2023 saw an influx driven by the Unity
      pricing controversy pulling developers toward the open-source alternative.
    </p>
    <div class="chart-card">{to_div(fig1)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">02</span>
      <span class="section-title">The Merge Clock</span></div>
    <p class="section-desc">
      The median PR is reviewed and merged in just {MEDIAN_TTM} days — but the mean jumps to {MEAN_TTM}.
      That gap tells a two-speed story: a fast lane of routine fixes, and a long-tail of
      complex features that take months or years to land.
    </p>
    <div class="insights">
      <div class="insight green">
        <strong>{WEEK_PCT}</strong> of all merges happen within the first week
      </div>
      <div class="insight orange">
        <strong>{LONG_TAIL:,} PRs</strong> took longer than a month to merge
      </div>
      <div class="insight red">
        <strong>{YEAR_WAIT:,} PRs</strong> waited over a full year before being merged
      </div>
    </div>
    <div class="chart-card">{to_div(fig2)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">03</span>
      <span class="section-title">The Contributor Funnel</span></div>
    <p class="section-desc">
      Recognition matters. First-time contributors achieve a 27% merge rate, while
      established collaborators land 93% of their PRs. Core members consistently push
      through the highest volume, forming the engine's backbone.
    </p>
    <div class="chart-card">{to_div(fig3)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">04</span>
      <span class="section-title">The Review Economy</span></div>
    <p class="section-desc">
      AThousandShips alone accounts for 1,885 reviews — nearly double the next contributor.
      The top 5 reviewers handle 40% of all reviews. More striking: only 6.6% of review
      submissions are formal approvals, revealing a culture of discussion over verdict.
    </p>
    <div class="insights">
      <div class="insight red">
        <strong>Top 5 reviewers</strong> handle 40% of all reviews — a significant bus-factor risk
      </div>
      <div class="insight orange">
        <strong>89.2%</strong> of reviews are COMMENTED — discussion without a formal verdict
      </div>
      <div class="insight green">
        <strong>714 Approvals</strong> vs 9,573 comments — formal sign-off is rare
      </div>
    </div>
    <div class="chart-card">{to_div(fig4)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">05</span>
      <span class="section-title">Community Wishlist</span></div>
    <p class="section-desc">
      These open PRs have the most community reactions — work people are actively waiting
      for. GDScript Traits leads with 468 reactions. The list is a window into Godot's
      most-wanted features that haven't yet made it to main.
    </p>
    <div class="chart-card">{to_div(fig5)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">06</span>
      <span class="section-title">Label Universe</span></div>
    <p class="section-desc">
      Enhancement and bug reports are nearly equal — 27,548 vs 26,961. The editor and
      core subsystems dominate the topic labels, while platform coverage spans Android,
      Windows, macOS, and Linux at comparable volumes.
    </p>
    <div class="chart-card">{to_div(fig6)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">07</span>
      <span class="section-title">The Aging Backlog</span></div>
    <p class="section-desc">
      Of the {OPEN_PRS:,} currently open PRs, some date back to {oldest_yr}. The chart reveals not just
      volume but the vintage of deferred decisions — design questions that have remained
      open for years, waiting for the right moment, reviewer, or consensus.
    </p>
    <div class="chart-card">{to_div(fig7)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">08</span>
      <span class="section-title">Codebase DNA</span></div>
    <p class="section-desc">
      C++ (<code>.cpp</code> + <code>.h</code>) accounts for 73% of all file changes — Godot is
      fundamentally an engine built in C++. The modest GDScript (<code>.gd</code>) and C#
      (<code>.cs</code>) numbers reflect that most contributors work at the engine layer,
      not the scripting layer.
    </p>
    <div class="chart-card">{to_div(fig8)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">09</span>
      <span class="section-title">The Size Penalty</span></div>
    <p class="section-desc">
      Tiny PRs (≤10 lines) merge at 78% — nearly double the rate of huge PRs (≤50%).
      The pattern is consistent and actionable: smaller, focused changes are dramatically
      more likely to land. Note: based on PRs with detail data fetched.
    </p>
    <div class="chart-card">{to_div(fig9)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">10</span>
      <span class="section-title">The Legends</span></div>
    <p class="section-desc">
      Calinou leads with nearly 3,000 PRs over a decade — an astonishing sustained output.
      The top 20 contributors account for a disproportionate share of the project's history,
      yet each brings a distinct focus area to the engine.
    </p>
    <div class="chart-card">{to_div(fig10)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">11</span>
      <span class="section-title">The Global Clock</span></div>
    <p class="section-desc">
      PR submissions peak at 13–17 UTC — European afternoon, US East morning — revealing
      where the contributor base is concentrated. Activity never falls silent: even at
      3am UTC, hundreds of PRs are opened each hour.
    </p>
    <div class="chart-card">{to_div(fig11)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">12</span>
      <span class="section-title">Codebase Hotspots</span></div>
    <p class="section-desc">
      The editor and scene subsystems see the most PR traffic. The <code>thirdparty/</code>
      directory shows modest PR count but outsized code churn — it's vendored dependencies
      being updated in bulk, not organic development.
    </p>
    <div class="chart-card">{to_div(fig12)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">13</span>
      <span class="section-title">Die Fast or Live Forever</span></div>
    <p class="section-desc">
      30% of PRs resolve on the day they're submitted. Half are gone within 3 days.
      But the curve flattens sharply after 30 days — PRs that survive a month tend to
      persist for months or years, becoming the aging backlog we saw in section 07.
    </p>
    <div class="chart-card">{to_div(fig13)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">14</span>
      <span class="section-title">What Travels with "bug"?</span></div>
    <p class="section-desc">
      Of {TOTAL_BUG_PRS:,} bug-labeled PRs, 30% also carry <code>topic:editor</code> — making the
      editor the single biggest source of reported bugs. <code>regression</code> appears on 1-in-8,
      and <code>crash</code> on 1-in-14, quantifying the severity tail of the bug backlog.
      Platform labels reveal that Windows and Android surface proportionally more bugs than
      other platforms.
    </p>
    <div class="chart-card">{to_div(fig14)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">15</span>
      <span class="section-title">The Bug Lift Chart</span></div>
    <p class="section-desc">
      Lift measures statistical association — how much more (or less) likely a label is
      on a bug PR versus any PR at random. <code>crash</code> and <code>regression</code>
      land at 2.05× — genuinely twice as predictive of bugs as the baseline. Meanwhile
      <code>feature proposal</code> (0.015×) and <code>topic:codestyle</code> (0.20×) are
      almost never bugs. Notably, <code>topic:editor</code> looks dominant in raw counts
      but its lift of 1.06× reveals it's just the biggest topic — not disproportionately buggy.
    </p>
    <div class="insights">
      <div class="insight red">
        <strong>crash · regression</strong> both sit at ~2.05× lift — the clearest bug signals
      </div>
      <div class="insight green">
        <strong>topic:input · topic:gdscript · topic:rendering</strong> all elevated above 1.25×
      </div>
      <div class="insight purple">
        <strong>feature proposal</strong> has lift 0.015× — essentially never a bug
      </div>
    </div>
    <div class="chart-card">{to_div(fig15)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">16</span>
      <span class="section-title">Bug Association Map</span></div>
    <p class="section-desc">
      Plotting volume (x, log scale) against lift (y) separates four quadrants: top-right
      is high-frequency and strongly bug-associated; bottom-right is common but not distinctive;
      top-left is rare but a strong signal when it appears; bottom-left barely interacts with
      bugs at all. Point size scales with total label usage across all PRs.
    </p>
    <div class="chart-card">{to_div(fig16)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">17</span>
      <span class="section-title">File Bug Proneness</span></div>
    <p class="section-desc">
      Each point is a source file. The x-axis shows total bug PR involvement (log scale);
      the y-axis shows lift — whether that file is disproportionately buggy relative to how
      often it's touched. Bubble size is the open bug backlog still waiting for a fix.
      Files in the top-right are both high-volume <em>and</em> genuinely overrepresented
      in bugs. Files on the bottom-right are busy but not especially bug-prone —
      they appear in bug PRs simply because they're touched all the time.
    </p>
    <div class="insights">
      <div class="insight red">
        <strong>scene/gui/popup_menu.cpp</strong> — highest lift (1.42×) among high-volume files
      </div>
      <div class="insight orange">
        <strong>scene/main/viewport.cpp</strong> — 40 open bug PRs, the largest unresolved backlog
      </div>
      <div class="insight purple">
        <strong>editor/editor_node.cpp</strong> — 210 bug PRs but lift 0.70× — it's just the busiest file
      </div>
    </div>
    <div class="chart-card">{to_div(fig17)}</div>
  </section>

  <section class="section">
    <div class="section-header"><span class="section-num">18</span>
      <span class="section-title">Bug Hotspot Map</span></div>
    <p class="section-desc">
      Tile area represents total bug PR count; color represents lift — blue tiles are
      expected given their activity, red/orange tiles are disproportionately bug-prone.
      Files are grouped by top-level directory, making it easy to see which subsystems
      concentrate the most bug debt and which files within them punch above their weight.
    </p>
    <div class="chart-card">{to_div(fig18)}</div>
  </section>

</div>

<footer>
  Data from the Godot Engine GitHub repository · {TOTAL_PRS:,} pull requests ·
  Generated {date.today().strftime("%B %Y")} · <em>{args.db}</em>
</footer>
</body>
</html>
"""

    out = "godot_analytics_dashboard.html"
    with open(out, "w", encoding="utf-8") as f:
        f.write(HTML)
    print(f"✓  Dashboard written to {out}  ({len(HTML):,} bytes)")

con.close()
