import argparse
import os
from datetime import date

import duckdb
import pandas as pd
import plotly.graph_objects as go
import plotly.express as px
from plotly.subplots import make_subplots

# ── CLI ────────────────────────────────────────────────────────────────────────

parser = argparse.ArgumentParser(description="Generate Godot PR analytics dashboard and social images")
parser.add_argument("--db", default="md:godot_prs",
                    help="DuckDB file path or MotherDuck URI (default: md:godot_prs)")
parser.add_argument("--output-dir", default="social",
                    help="Output directory for social media PNGs (default: social/)")
parser.add_argument("--no-html",   action="store_true", help="Skip HTML dashboard output")
parser.add_argument("--no-images", action="store_true", help="Skip PNG image export")
args = parser.parse_args()

con = duckdb.connect(args.db)

# ── Palette ────────────────────────────────────────────────────────────────────

BG     = "#0d1117"
CARD   = "#161b22"
BORDER = "#30363d"
BLUE   = "#478CBF"
CYAN   = "#79C0FF"
GREEN  = "#3FB950"
ORANGE = "#FF8C42"
RED    = "#F85149"
PURPLE = "#BC8CFF"
YELLOW = "#E3B341"
TEXT   = "#e6edf3"
MUTED  = "#8b949e"

FONT = dict(family="'Inter','Segoe UI',system-ui,sans-serif", color=TEXT, size=13)

def base_layout(t=70, **kw):
    return dict(
        paper_bgcolor=CARD,
        plot_bgcolor=CARD,
        font=FONT,
        margin=dict(l=20, r=20, t=t, b=20),
        **kw,
    )

# ── KPI values (computed from DB) ─────────────────────────────────────────────

counts = con.execute("""
    SELECT
        COUNT(*)                                                              AS total,
        SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END)               AS merged,
        SUM(CASE WHEN state = 'open'        THEN 1 ELSE 0 END)               AS open_prs
    FROM pull_requests
""").fetchone()
TOTAL_PRS, MERGED, OPEN_PRS = counts

ttm_stats = con.execute("""
    SELECT
        CAST(MEDIAN(DATEDIFF('day', created_at, merged_at)) AS INTEGER)      AS median_ttm,
        ROUND(AVG(DATEDIFF('day', created_at, merged_at)), 1)                AS mean_ttm,
        SUM(CASE WHEN DATEDIFF('day', created_at, merged_at) <= 7  THEN 1 ELSE 0 END) AS week_merges,
        SUM(CASE WHEN DATEDIFF('day', created_at, merged_at) > 30  THEN 1 ELSE 0 END) AS long_tail,
        SUM(CASE WHEN DATEDIFF('day', created_at, merged_at) > 365 THEN 1 ELSE 0 END) AS year_wait
    FROM pull_requests WHERE merged_at IS NOT NULL
""").fetchone()
MEDIAN_TTM, MEAN_TTM, WEEK_MERGES, LONG_TAIL, YEAR_WAIT = ttm_stats

FILE_CHANGES = con.execute("SELECT COUNT(*) FROM pr_files").fetchone()[0]
FIRST_PR_YEAR = con.execute("SELECT YEAR(MIN(created_at)) FROM pull_requests").fetchone()[0]

MERGE_RATE = f"{100 * MERGED / TOTAL_PRS:.1f}%"
WEEK_PCT   = f"{100 * WEEK_MERGES / MERGED:.1f}%"
YEARS_SPAN = date.today().year - FIRST_PR_YEAR

# ── 1. PR Volume by Year ───────────────────────────────────────────────────────

yr = con.execute("""
    SELECT YEAR(created_at) yr,
           COUNT(*) total,
           SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END) merged,
           SUM(CASE WHEN state='open' THEN 1 ELSE 0 END) still_open
    FROM pull_requests
    GROUP BY yr ORDER BY yr
""").df()
yr["closed_unmerged"] = yr["total"] - yr["merged"] - yr["still_open"]
yr["merge_rate"]      = 100 * yr["merged"] / yr["total"]

fig1 = go.Figure()
fig1.add_trace(go.Bar(x=yr["yr"], y=yr["merged"],         name="Merged",           marker_color=GREEN,  hovertemplate="%{y:,} merged<extra></extra>"))
fig1.add_trace(go.Bar(x=yr["yr"], y=yr["closed_unmerged"],name="Closed (unmerged)", marker_color=RED,    hovertemplate="%{y:,} closed unmerged<extra></extra>"))
fig1.add_trace(go.Bar(x=yr["yr"], y=yr["still_open"],     name="Still Open",        marker_color=YELLOW, hovertemplate="%{y:,} still open<extra></extra>"))
fig1.add_trace(go.Scatter(
    x=yr["yr"], y=yr["merge_rate"], name="Merge Rate %", yaxis="y2",
    line=dict(color=CYAN, width=2.5, dash="dot"), mode="lines+markers",
    marker=dict(size=5), hovertemplate="%{y:.1f}% merge rate<extra></extra>",
))
fig1.update_layout(**base_layout(
    t=100,
    title=dict(text="PR Submissions & Outcomes by Year", font=dict(size=16, color=TEXT), x=0),
    barmode="stack",
    legend=dict(orientation="h", x=0, y=1.13, bgcolor="rgba(0,0,0,0)"),
    xaxis=dict(dtick=1, gridcolor=BORDER),
    yaxis=dict(gridcolor=BORDER, title="Pull Requests"),
    yaxis2=dict(overlaying="y", side="right", range=[0, 110], ticksuffix="%",
                gridcolor="rgba(0,0,0,0)", title="Merge Rate"),
    hovermode="x unified",
))

# ── 2. Time to Merge ───────────────────────────────────────────────────────────

ttm = con.execute("""
    SELECT
        CASE
            WHEN days = 0           THEN 'Same day'
            WHEN days <= 3          THEN '1–3 days'
            WHEN days <= 7          THEN '4–7 days'
            WHEN days <= 30         THEN '1–4 weeks'
            WHEN days <= 90         THEN '1–3 months'
            WHEN days <= 365        THEN '3–12 months'
            ELSE                         '1+ year'
        END AS bucket,
        COUNT(*) AS cnt,
        CASE
            WHEN days = 0    THEN 0 WHEN days <= 3   THEN 1
            WHEN days <= 7   THEN 2 WHEN days <= 30  THEN 3
            WHEN days <= 90  THEN 4 WHEN days <= 365 THEN 5
            ELSE 6
        END AS ord
    FROM (SELECT DATEDIFF('day', created_at, merged_at) AS days
          FROM pull_requests WHERE merged_at IS NOT NULL)
    GROUP BY bucket, ord ORDER BY ord
""").df()
ttm["pct"] = 100 * ttm["cnt"] / ttm["cnt"].sum()
ttm_colors = [GREEN, "#4ade80", "#86efac", YELLOW, ORANGE, RED, "#7f1d1d"]

fig2 = go.Figure(go.Bar(
    x=ttm["cnt"], y=ttm["bucket"],
    orientation="h",
    marker_color=ttm_colors[:len(ttm)],
    text=[f"{p:.1f}%" for p in ttm["pct"]],
    textposition="outside",
    textfont=dict(color=TEXT, size=12),
    hovertemplate="<b>%{y}</b><br>%{x:,} PRs (%{text})<extra></extra>",
    width=0.65,
))
fig2.update_layout(**base_layout(
    title=dict(text=f"Time-to-Merge Distribution  ({MERGED:,} merged PRs)", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER, title="Number of PRs"),
    yaxis=dict(autorange="reversed", gridcolor="rgba(0,0,0,0)"),
    showlegend=False,
))
fig2.update_layout(margin=dict(l=20, r=80, t=50, b=20))

# ── 3. Contributor Funnel ──────────────────────────────────────────────────────

assoc = con.execute("""
    SELECT author_association,
           COUNT(*) total,
           SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END) merged
    FROM pull_requests GROUP BY author_association ORDER BY total DESC
""").df()
assoc["merge_rate"]  = 100 * assoc["merged"] / assoc["total"]
assoc["not_merged"]  = assoc["total"] - assoc["merged"]
assoc["label"] = assoc["author_association"].map({
    "CONTRIBUTOR": "Contributors", "MEMBER": "Core Members",
    "NONE": "First-timers", "COLLABORATOR": "Collaborators",
})

fig3 = make_subplots(rows=1, cols=2,
    subplot_titles=["Volume by Contributor Type", "Merge Rate by Type"],
    column_widths=[0.55, 0.45])
fig3.add_trace(go.Bar(x=assoc["label"], y=assoc["merged"],     name="Merged",     marker_color=GREEN), row=1, col=1)
fig3.add_trace(go.Bar(x=assoc["label"], y=assoc["not_merged"], name="Not Merged", marker_color=RED),   row=1, col=1)
fig3.add_trace(go.Bar(
    x=assoc["label"], y=assoc["merge_rate"],
    name="Merge %", showlegend=False,
    marker_color=[GREEN, BLUE, ORANGE, PURPLE],
    text=[f"{r:.1f}%" for r in assoc["merge_rate"]],
    textposition="outside",
    hovertemplate="<b>%{x}</b><br>%{y:.1f}% merge rate<extra></extra>",
), row=1, col=2)
fig3.update_layout(**base_layout(
    t=100,
    title=dict(text="The Contributor Funnel", font=dict(size=16, color=TEXT), x=0),
    barmode="stack",
    legend=dict(orientation="h", x=0, y=1.15, bgcolor="rgba(0,0,0,0)"),
    yaxis=dict(gridcolor=BORDER),
    yaxis2=dict(gridcolor=BORDER, range=[0, 112], ticksuffix="%"),
    xaxis=dict(gridcolor="rgba(0,0,0,0)"),
    xaxis2=dict(gridcolor="rgba(0,0,0,0)"),
))
fig3.update_annotations(font_color=MUTED)

# ── 4. Review Economy ──────────────────────────────────────────────────────────

rev_top = con.execute("""
    SELECT reviewer_login,
           COUNT(*) reviews,
           SUM(CASE WHEN state='APPROVED'           THEN 1 ELSE 0 END) approvals,
           SUM(CASE WHEN state='CHANGES_REQUESTED'  THEN 1 ELSE 0 END) changes_req
    FROM pr_reviews GROUP BY reviewer_login ORDER BY reviews DESC LIMIT 15
""").df()

rev_states = con.execute("SELECT state, COUNT(*) cnt FROM pr_reviews GROUP BY state").df()

fig4 = make_subplots(rows=1, cols=2,
    subplot_titles=["Top 15 Reviewers", "Review Verdicts"],
    column_widths=[0.65, 0.35],
    specs=[[{"type": "bar"}, {"type": "pie"}]])

fig4.add_trace(go.Bar(
    x=rev_top["reviews"], y=rev_top["reviewer_login"], orientation="h",
    name="Reviews", marker_color=BLUE,
    hovertemplate="<b>%{y}</b><br>%{x} reviews<extra></extra>",
), row=1, col=1)
fig4.add_trace(go.Bar(
    x=rev_top["approvals"], y=rev_top["reviewer_login"], orientation="h",
    name="Approvals", marker_color=GREEN,
    hovertemplate="<b>%{y}</b><br>%{x} approvals<extra></extra>",
), row=1, col=1)

state_colors = {"COMMENTED": BLUE, "APPROVED": GREEN, "CHANGES_REQUESTED": ORANGE, "DISMISSED": MUTED}
fig4.add_trace(go.Pie(
    labels=rev_states["state"], values=rev_states["cnt"],
    marker_colors=[state_colors.get(s, MUTED) for s in rev_states["state"]],
    hole=0.55,
    textinfo="label+percent", textfont=dict(size=11),
    hovertemplate="<b>%{label}</b><br>%{value:,} (%{percent})<extra></extra>",
), row=1, col=2)
fig4.update_layout(**base_layout(
    t=100,
    title=dict(text="The Review Economy", font=dict(size=16, color=TEXT), x=0),
    barmode="overlay",
    legend=dict(orientation="h", x=0, y=1.15, bgcolor="rgba(0,0,0,0)"),
    xaxis=dict(gridcolor=BORDER),
    yaxis=dict(autorange="reversed", gridcolor="rgba(0,0,0,0)"),
))
fig4.update_annotations(font_color=MUTED)

# ── 5. Community Wishlist ──────────────────────────────────────────────────────

wish = con.execute("""
    SELECT number,
           CASE WHEN LENGTH(title) > 55 THEN LEFT(title, 52) || '…' ELSE title END title_short,
           title, reactions_total, reactions_plus1, comments
    FROM pull_requests
    WHERE state='open' AND merged_at IS NULL AND reactions_total > 20
    ORDER BY reactions_total DESC LIMIT 12
""").df().sort_values("reactions_total")

fig5 = go.Figure(go.Bar(
    x=wish["reactions_total"], y=wish["title_short"],
    orientation="h",
    marker=dict(color=wish["reactions_total"],
                colorscale=[[0, BLUE], [1, PURPLE]], showscale=False),
    text=[f"#{n}" for n in wish["number"]],
    textposition="outside",
    textfont=dict(color=MUTED, size=10),
    customdata=list(zip(wish["number"], wish["reactions_plus1"], wish["comments"], wish["title"])),
    hovertemplate="<b>#%{customdata[0]}</b><br>%{customdata[3]}<br>👍 %{customdata[1]}  💬 %{customdata[2]}<extra></extra>",
    width=0.7,
))
fig5.update_layout(**base_layout(
    title=dict(text="Community Wishlist — Most-Wanted Open PRs", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER, title="Total Reactions"),
    yaxis=dict(gridcolor="rgba(0,0,0,0)"),
    showlegend=False,
    height=480,
))
fig5.update_layout(margin=dict(l=20, r=60, t=50, b=20))

# ── 6. Label Treemap ───────────────────────────────────────────────────────────

lbl = con.execute("""
    SELECT label_name, COUNT(*) cnt
    FROM pr_labels GROUP BY label_name ORDER BY cnt DESC LIMIT 35
""").df()

def label_cat(name):
    if name.startswith("topic:"):      return "Topic"
    if name.startswith("platform:"):   return "Platform"
    if name.startswith("cherrypick:"): return "Cherry-pick"
    if name in ("bug","enhancement","documentation","usability","performance",
                "regression","crash","feature proposal","breaks compat","archived"): return "Type"
    return "Other"

lbl["category"] = lbl["label_name"].apply(label_cat)
lbl["display"]  = lbl["label_name"].str.replace(r"^(topic:|platform:)", "", regex=True)

fig6 = px.treemap(lbl, path=["category","display"], values="cnt",
                  color="cnt",
                  color_continuous_scale=[[0,"#1a3a5c"],[0.5,BLUE],[1,PURPLE]])
fig6.update_layout(**base_layout(
    title=dict(text="Godot's Label Universe", font=dict(size=16, color=TEXT), x=0),
    coloraxis_showscale=False,
    height=480,
))
fig6.update_traces(
    textfont=dict(color="white", size=12),
    hovertemplate="<b>%{label}</b><br>%{value:,} PRs<extra></extra>",
)

# ── 7. Open PR Backlog by Age ──────────────────────────────────────────────────

backlog = con.execute("""
    SELECT YEAR(created_at) yr, COUNT(*) open_count
    FROM pull_requests WHERE state='open'
    GROUP BY yr ORDER BY yr
""").df()

oldest_yr = int(backlog["yr"].min()) if not backlog.empty else FIRST_PR_YEAR

fig7 = go.Figure(go.Bar(
    x=backlog["yr"], y=backlog["open_count"],
    marker=dict(color=backlog["yr"],
                colorscale=[[0, RED],[0.5, ORANGE],[1, YELLOW]], showscale=False),
    text=backlog["open_count"],
    textposition="outside",
    textfont=dict(size=11, color=TEXT),
    hovertemplate="<b>%{x}</b><br>%{y} PRs still open<extra></extra>",
    width=0.7,
))
annotations = []
if not backlog.empty:
    oldest_count = int(backlog[backlog["yr"] == oldest_yr]["open_count"].values[0])
    annotations = [dict(
        x=oldest_yr,
        y=oldest_count + 3,
        text=f"⚠️ PRs from {oldest_yr}<br>still open!",
        showarrow=True, arrowhead=2, arrowcolor=RED,
        font=dict(color=RED, size=11), ax=70, ay=-40,
    )]
fig7.update_layout(**base_layout(
    title=dict(text="Open PR Backlog — Submitted Year of Currently Open PRs", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(dtick=1, gridcolor=BORDER, title="Year submitted"),
    yaxis=dict(gridcolor=BORDER, title="Currently open PRs"),
    showlegend=False,
    annotations=annotations,
))

# ── 8. File Extension Donut ────────────────────────────────────────────────────

ext = con.execute(r"""
    SELECT regexp_extract(filename, '\.(\w+)$', 1) ext, COUNT(*) cnt
    FROM pr_files
    WHERE regexp_extract(filename, '\.(\w+)$', 1) != ''
    GROUP BY ext ORDER BY cnt DESC LIMIT 12
""").df()

ext_palette = [BLUE, CYAN, GREEN, ORANGE, PURPLE, YELLOW, RED,
               "#20B2AA","#DDA0DD","#FA8072","#90EE90", MUTED]
fig8 = go.Figure(go.Pie(
    labels=ext["ext"], values=ext["cnt"],
    marker_colors=ext_palette[:len(ext)],
    hole=0.6,
    textinfo="label+percent", textfont=dict(size=12),
    hovertemplate="<b>.%{label}</b><br>%{value:,} files (%{percent})<extra></extra>",
))
fig8.update_layout(**base_layout(
    title=dict(text="Codebase DNA — Files Changed by Extension", font=dict(size=16, color=TEXT), x=0),
    legend=dict(orientation="v", x=1.0, y=0.5, bgcolor="rgba(0,0,0,0)"),
    height=400,
    annotations=[dict(text=f"{FILE_CHANGES:,}<br>file changes", x=0.5, y=0.5,
                      font_size=14, font_color=TEXT, showarrow=False, xanchor="center")],
))

# ── 9. PR Size vs Merge Rate ──────────────────────────────────────────────────

size_df = con.execute("""
    SELECT
        CASE
            WHEN additions + deletions <= 10   THEN 'Tiny (≤10)'
            WHEN additions + deletions <= 100  THEN 'Small (≤100)'
            WHEN additions + deletions <= 500  THEN 'Medium (≤500)'
            WHEN additions + deletions <= 2000 THEN 'Large (≤2k)'
            ELSE                                    'Huge (2k+)'
        END AS size,
        CASE
            WHEN additions + deletions <= 10   THEN 1
            WHEN additions + deletions <= 100  THEN 2
            WHEN additions + deletions <= 500  THEN 3
            WHEN additions + deletions <= 2000 THEN 4
            ELSE                                    5
        END AS ord,
        COUNT(*) AS total,
        SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END) AS merged,
        ROUND(100.0 * SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END) / COUNT(*), 1) AS merge_rate
    FROM pull_requests
    WHERE additions IS NOT NULL AND additions + deletions > 0
    GROUP BY size, ord ORDER BY ord
""").df()

fig9 = make_subplots(rows=1, cols=2,
    subplot_titles=["PRs by Size", "Merge Rate by Size"],
    column_widths=[0.5, 0.5])
size_colors = [GREEN, "#4ade80", YELLOW, ORANGE, RED]
fig9.add_trace(go.Bar(
    x=size_df["size"], y=size_df["total"],
    marker_color=size_colors[:len(size_df)],
    hovertemplate="<b>%{x}</b><br>%{y:,} PRs<extra></extra>",
    showlegend=False,
), row=1, col=1)
fig9.add_trace(go.Bar(
    x=size_df["size"], y=size_df["merge_rate"],
    marker_color=size_colors[:len(size_df)],
    text=[f"{r}%" for r in size_df["merge_rate"]],
    textposition="outside",
    textfont=dict(color=TEXT, size=12),
    hovertemplate="<b>%{x}</b><br>%{y:.1f}% merge rate<extra></extra>",
    showlegend=False,
), row=1, col=2)
fig9.update_layout(**base_layout(
    t=100,
    title=dict(text="PR Size vs Merge Rate — Keep It Small", font=dict(size=16, color=TEXT), x=0),
    yaxis=dict(gridcolor=BORDER, title="PRs"),
    yaxis2=dict(gridcolor=BORDER, range=[0, 105], ticksuffix="%", title="Merge Rate"),
    xaxis=dict(gridcolor="rgba(0,0,0,0)"),
    xaxis2=dict(gridcolor="rgba(0,0,0,0)"),
))
fig9.update_annotations(font_color=MUTED)

# ── 10. Contributor Leaderboard ────────────────────────────────────────────────

contrib_df = con.execute("""
    SELECT
        author_login,
        COUNT(*) AS total_prs,
        SUM(CASE WHEN merged_at IS NOT NULL THEN 1 ELSE 0 END) AS merged
    FROM pull_requests
    WHERE author_login IS NOT NULL AND author_login != 'ghost'
    GROUP BY author_login
    ORDER BY total_prs DESC
    LIMIT 20
""").df()
contrib_df["not_merged"] = contrib_df["total_prs"] - contrib_df["merged"]

fig10 = go.Figure()
fig10.add_trace(go.Bar(
    x=contrib_df["merged"], y=contrib_df["author_login"],
    orientation="h", name="Merged", marker_color=GREEN,
    hovertemplate="<b>%{y}</b><br>%{x:,} merged<extra></extra>",
))
fig10.add_trace(go.Bar(
    x=contrib_df["not_merged"], y=contrib_df["author_login"],
    orientation="h", name="Not Merged", marker_color=MUTED,
    hovertemplate="<b>%{y}</b><br>%{x:,} not merged<extra></extra>",
))
fig10.update_layout(**base_layout(
    t=100,
    title=dict(text="All-Time PR Leaderboard — Top 20 Contributors", font=dict(size=16, color=TEXT), x=0),
    barmode="stack",
    legend=dict(orientation="h", x=0, y=1.12, bgcolor="rgba(0,0,0,0)"),
    xaxis=dict(gridcolor=BORDER, title="Pull Requests"),
    yaxis=dict(autorange="reversed", gridcolor="rgba(0,0,0,0)"),
    height=560,
))

# ── 11. Activity by Hour of Day (UTC) ─────────────────────────────────────────

hour_df = con.execute("""
    SELECT HOUR(created_at) AS hour_utc, COUNT(*) AS prs
    FROM pull_requests
    GROUP BY hour_utc ORDER BY hour_utc
""").df()

def _hour_color(h):
    if 13 <= h <= 17: return ORANGE
    if  9 <= h <= 20: return BLUE
    return "#1e3a5f"

fig11 = go.Figure(go.Bar(
    x=hour_df["hour_utc"],
    y=hour_df["prs"],
    marker_color=[_hour_color(h) for h in hour_df["hour_utc"]],
    hovertemplate="<b>%{x}:00 UTC</b><br>%{y:,} PRs opened<extra></extra>",
))
fig11.update_layout(**base_layout(
    title=dict(text="When Does the World Contribute? — PRs by Hour (UTC)", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(
        gridcolor=BORDER, title="Hour of Day (UTC)",
        tickvals=list(range(0, 24, 2)),
        ticktext=["12am","2am","4am","6am","8am","10am","12pm","2pm","4pm","6pm","8pm","10pm"],
    ),
    yaxis=dict(gridcolor=BORDER, title="PRs Opened"),
    showlegend=False,
))

# ── 12. Codebase Hotspots by Directory ────────────────────────────────────────

dirs_df = con.execute("""
    SELECT
        SPLIT_PART(filename, '/', 1) AS top_dir,
        COUNT(DISTINCT pr_number) AS pr_count,
        ROUND(SUM(additions + deletions) / 1000.0, 1) AS churn_kloc
    FROM pr_files
    WHERE filename LIKE '%/%'
    GROUP BY top_dir
    ORDER BY pr_count DESC
    LIMIT 12
""").df()

dir_colors = [BLUE, CYAN, GREEN, PURPLE, ORANGE, YELLOW, RED,
              "#20B2AA","#DDA0DD","#FA8072","#90EE90", MUTED]

fig12 = make_subplots(rows=1, cols=2,
    subplot_titles=["PRs Touching Directory", "Code Churn (k lines)"],
    column_widths=[0.5, 0.5])
fig12.add_trace(go.Bar(
    x=dirs_df["pr_count"], y=dirs_df["top_dir"],
    orientation="h", marker_color=dir_colors[:len(dirs_df)],
    hovertemplate="<b>%{y}/</b><br>%{x:,} PRs<extra></extra>",
    showlegend=False,
), row=1, col=1)
fig12.add_trace(go.Bar(
    x=dirs_df["churn_kloc"], y=dirs_df["top_dir"],
    orientation="h", marker_color=dir_colors[:len(dirs_df)],
    hovertemplate="<b>%{y}/</b><br>%{x:.1f}k lines changed<extra></extra>",
    showlegend=False,
), row=1, col=2)
fig12.update_layout(**base_layout(
    t=100,
    title=dict(text="Codebase Hotspots — Where Work Happens", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER),
    xaxis2=dict(gridcolor=BORDER),
    yaxis=dict(autorange="reversed", gridcolor="rgba(0,0,0,0)"),
    yaxis2=dict(autorange="reversed", gridcolor="rgba(0,0,0,0)"),
    height=480,
))
fig12.update_annotations(font_color=MUTED)

# ── 13. PR Resolution Curve ────────────────────────────────────────────────────

survival_df = con.execute("""
    WITH closed AS (
        SELECT DATEDIFF('day', created_at, COALESCE(merged_at, closed_at)) AS age
        FROM pull_requests
        WHERE state != 'open' AND COALESCE(merged_at, closed_at) IS NOT NULL
    ),
    buckets AS (
        SELECT
            CASE
                WHEN age = 0    THEN 0   WHEN age <= 1   THEN 1
                WHEN age <= 3   THEN 3   WHEN age <= 7   THEN 7
                WHEN age <= 14  THEN 14  WHEN age <= 30  THEN 30
                WHEN age <= 60  THEN 60  WHEN age <= 90  THEN 90
                WHEN age <= 180 THEN 180 WHEN age <= 365 THEN 365
                ELSE 730
            END AS bucket,
            COUNT(*) AS cnt
        FROM closed GROUP BY bucket
    )
    SELECT
        bucket AS days,
        ROUND(100.0 * SUM(cnt) OVER (ORDER BY bucket) / SUM(cnt) OVER (), 1) AS pct_closed
    FROM buckets ORDER BY bucket
""").df()

_day_labels = {0:"Same day",1:"1 day",3:"3 days",7:"1 week",14:"2 weeks",
               30:"1 month",60:"2 months",90:"3 months",180:"6 months",
               365:"1 year",730:"2 years+"}
survival_df["label"] = survival_df["days"].map(_day_labels)

fig13 = go.Figure()
fig13.add_trace(go.Scatter(
    x=survival_df["label"], y=survival_df["pct_closed"],
    mode="lines+markers",
    line=dict(color=BLUE, width=3),
    marker=dict(size=9, color=BLUE, line=dict(color=CARD, width=2)),
    fill="tozeroy", fillcolor="rgba(71,140,191,0.15)",
    hovertemplate="<b>%{x}</b><br>%{y:.1f}% of PRs resolved<extra></extra>",
))
fig13.update_layout(**base_layout(
    title=dict(text="PR Resolution Curve — Half Close in 3 Days, 4% Live Forever", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER, title="Time Since Submission"),
    yaxis=dict(gridcolor=BORDER, title="Cumulative % Resolved", range=[0, 105], ticksuffix="%"),
    showlegend=False,
))

# ── 14. Bug Label Co-occurrence ───────────────────────────────────────────────

TOTAL_BUG_PRS = con.execute(
    "SELECT COUNT(DISTINCT pr_number) FROM pr_labels WHERE label_name = 'bug'"
).fetchone()[0]

bug_co = con.execute("""
    SELECT b.label_name AS co_label, COUNT(*) AS cnt
    FROM pr_labels a
    JOIN pr_labels b ON a.pr_number = b.pr_number AND b.label_name != 'bug'
    WHERE a.label_name = 'bug'
      AND b.label_name NOT LIKE 'cherrypick:%'
      AND b.label_name NOT IN ('archived', 'enhancement', 'breaks compat')
    GROUP BY b.label_name
    ORDER BY cnt DESC
    LIMIT 25
""").df()

bug_co["pct"] = (100 * bug_co["cnt"] / TOTAL_BUG_PRS).round(1)
bug_co["display"] = bug_co["co_label"].str.replace(r"^(topic:|platform:)", "", regex=True)

def _bug_label_color(name):
    if name.startswith("topic:"):    return BLUE
    if name.startswith("platform:"): return ORANGE
    if name == "regression":         return RED
    if name == "crash":              return "#c0392b"
    if name == "usability":          return PURPLE
    if name == "documentation":      return MUTED
    return CYAN

bug_co["color"] = bug_co["co_label"].apply(_bug_label_color)
bug_co = bug_co.sort_values("cnt")  # ascending so largest is at top in horizontal bar

fig14 = go.Figure(go.Bar(
    x=bug_co["pct"],
    y=bug_co["display"],
    orientation="h",
    marker_color=bug_co["color"].tolist(),
    text=[f"{p}%" for p in bug_co["pct"]],
    textposition="outside",
    textfont=dict(color=TEXT, size=11),
    customdata=list(zip(bug_co["co_label"], bug_co["cnt"])),
    hovertemplate="<b>%{customdata[0]}</b><br>%{x:.1f}% of bug PRs (%{customdata[1]:,})<extra></extra>",
    width=0.7,
))

# Legend annotations
legend_items = [
    ("Topic",    BLUE,   0.62),
    ("Platform", ORANGE, 0.72),
    ("Severity", RED,    0.82),
    ("Other",    CYAN,   0.92),
]
annotations = [
    dict(x=ann_x, y=1.06, xref="paper", yref="paper", showarrow=False,
         text=f"<b style='color:{c}'>{lbl}</b>",
         font=dict(size=11, color=c))
    for lbl, c, ann_x in legend_items
]

fig14.update_layout(**base_layout(
    t=90,
    title=dict(text="What Travels with 'bug'? — Label Co-occurrence on Bug PRs", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER, title=f"% of {TOTAL_BUG_PRS:,} bug-labeled PRs", ticksuffix="%", range=[0, 38]),
    yaxis=dict(gridcolor="rgba(0,0,0,0)"),
    showlegend=False,
    annotations=annotations,
    height=700,
))
fig14.update_layout(margin=dict(l=20, r=80, t=90, b=20))

# ── 15. Bug Label Lift — Diverging Bar ────────────────────────────────────────

lift_df = con.execute("""
    WITH totals    AS (SELECT COUNT(*) AS total_prs FROM pull_requests),
    bug_total      AS (SELECT COUNT(DISTINCT pr_number) AS bug_prs FROM pr_labels WHERE label_name = 'bug'),
    bug_prs        AS (SELECT DISTINCT pr_number FROM pr_labels WHERE label_name = 'bug'),
    label_counts   AS (
        SELECT label_name, COUNT(DISTINCT pr_number) AS total_cnt
        FROM pr_labels
        WHERE label_name NOT IN ('bug','archived','enhancement','breaks compat')
          AND label_name NOT LIKE 'cherrypick:%'
        GROUP BY label_name
    ),
    bug_co AS (
        SELECT l.label_name, COUNT(*) AS bug_cnt
        FROM pr_labels l
        JOIN bug_prs ON l.pr_number = bug_prs.pr_number
        WHERE l.label_name NOT IN ('bug','archived','enhancement','breaks compat')
          AND l.label_name NOT LIKE 'cherrypick:%'
        GROUP BY l.label_name
    )
    SELECT
        lc.label_name,
        lc.total_cnt,
        COALESCE(bc.bug_cnt, 0) AS bug_cnt,
        ROUND(100.0 * COALESCE(bc.bug_cnt, 0) / bt.bug_prs, 2) AS pct_of_bugs,
        ROUND(
            (COALESCE(bc.bug_cnt, 0)::DOUBLE / bt.bug_prs) /
            (lc.total_cnt::DOUBLE / t.total_prs), 3
        ) AS lift
    FROM label_counts lc
    LEFT JOIN bug_co bc ON lc.label_name = bc.label_name
    CROSS JOIN totals t CROSS JOIN bug_total bt
    WHERE lc.total_cnt >= 100
    ORDER BY lift DESC
""").df()

lift_df["display"] = lift_df["label_name"].str.replace(r"^(topic:|platform:)", "", regex=True)

def _lift_bar_color(lift):
    if lift >= 1.8: return "#c0392b"
    if lift >= 1.3: return RED
    if lift >= 1.1: return ORANGE
    if lift >= 0.9: return YELLOW
    if lift >= 0.6: return CYAN
    if lift >= 0.3: return BLUE
    return "#1a3a6c"

bar_df = lift_df.sort_values("lift")  # ascending → highest lift at top

fig15 = go.Figure(go.Bar(
    x=bar_df["lift"],
    y=bar_df["display"],
    orientation="h",
    marker_color=[_lift_bar_color(v) for v in bar_df["lift"]],
    text=[f"{v:.2f}×" for v in bar_df["lift"]],
    textposition="outside",
    textfont=dict(color=TEXT, size=10),
    customdata=list(zip(bar_df["label_name"], bar_df["bug_cnt"], bar_df["pct_of_bugs"])),
    hovertemplate="<b>%{customdata[0]}</b><br>Lift: %{x:.3f}×<br>%{customdata[1]:,} bug PRs (%{customdata[2]:.1f}%)<extra></extra>",
    width=0.75,
))
fig15.add_vline(x=1.0, line_color=MUTED, line_dash="dash", line_width=1.5,
                annotation_text="baseline", annotation_position="top",
                annotation_font=dict(color=MUTED, size=10))
fig15.update_layout(**base_layout(
    t=80,
    title=dict(text="Bug Label Lift — Which Labels Are Disproportionately Associated with Bugs?", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(gridcolor=BORDER, title="Lift  (1.0 = same rate as all PRs)", range=[0, 2.6]),
    yaxis=dict(gridcolor="rgba(0,0,0,0)"),
    showlegend=False,
    height=900,
))
fig15.update_layout(margin=dict(l=20, r=80, t=80, b=20))

# ── 16. Bug Association Scatter — Volume vs. Lift ─────────────────────────────

ANNOTATE_LABELS = {
    "crash", "regression", "feature proposal", "topic:editor",
    "performance", "topic:input", "topic:codestyle", "documentation",
    "usability", "topic:rendering", "topic:gdscript",
}

def _scatter_cat(name):
    if name.startswith("topic:"):        return "Topic",    BLUE
    if name.startswith("platform:"):     return "Platform", ORANGE
    if name in ("crash", "regression"):  return "Severity", RED
    return "Other", PURPLE

fig16 = go.Figure()
for cat_key, cat_label, color in [
    ("topic",    "Topic",                    BLUE),
    ("platform", "Platform",                 ORANGE),
    ("severity", "Severity (crash/regress)", RED),
    ("other",    "Other",                    PURPLE),
]:
    if   cat_key == "topic":    mask = lift_df["label_name"].str.startswith("topic:")
    elif cat_key == "platform": mask = lift_df["label_name"].str.startswith("platform:")
    elif cat_key == "severity": mask = lift_df["label_name"].isin(["crash","regression"])
    else:
        mask = (~lift_df["label_name"].str.startswith("topic:") &
                ~lift_df["label_name"].str.startswith("platform:") &
                ~lift_df["label_name"].isin(["crash","regression"]))
    sub = lift_df[mask]
    fig16.add_trace(go.Scatter(
        x=sub["bug_cnt"], y=sub["lift"],
        mode="markers", name=cat_label,
        marker=dict(
            color=color,
            size=(sub["total_cnt"] ** 0.38).clip(8, 36),
            opacity=0.85,
            line=dict(color=CARD, width=1.5),
        ),
        customdata=list(zip(sub["label_name"], sub["total_cnt"], sub["pct_of_bugs"])),
        hovertemplate="<b>%{customdata[0]}</b><br>Bug co-occurrences: %{x:,}<br>Lift: %{y:.3f}×<br>Total uses: %{customdata[1]:,}<br>On %{customdata[2]:.1f}% of bug PRs<extra></extra>",
    ))

ann16 = lift_df[lift_df["label_name"].isin(ANNOTATE_LABELS)]
fig16.add_trace(go.Scatter(
    x=ann16["bug_cnt"], y=ann16["lift"],
    mode="text",
    text=ann16["display"],
    textposition="top right",
    textfont=dict(size=9, color=TEXT),
    showlegend=False,
    hoverinfo="skip",
))

fig16.add_hline(y=1.0, line_color=MUTED, line_dash="dash", line_width=1.5,
                annotation_text="lift = 1.0 (baseline)", annotation_position="right",
                annotation_font=dict(color=MUTED, size=10))
fig16.update_layout(**base_layout(
    t=100,
    title=dict(text="Bug Association Map — Volume vs. Statistical Lift", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(type="log", gridcolor=BORDER, title="Co-occurrences with 'bug' (log scale)"),
    yaxis=dict(gridcolor=BORDER, title="Lift  (×baseline rate)", range=[-0.15, 2.35]),
    legend=dict(orientation="h", x=0, y=1.13, bgcolor="rgba(0,0,0,0)"),
    hovermode="closest",
))

# ── 17 & 18. File Bug Proneness ────────────────────────────────────────────────

file_bug_df = con.execute("""
    WITH file_totals AS (
        SELECT filename,
               SPLIT_PART(filename, '/', 1) AS top_dir,
               COUNT(DISTINCT pr_number)    AS total_prs
        FROM pr_files GROUP BY filename
    ),
    bug_prs_all AS (
        SELECT DISTINCT p.number AS pr_number, p.state
        FROM pull_requests p
        JOIN pr_labels l ON p.number = l.pr_number
        WHERE l.label_name = 'bug'
    ),
    file_bugs AS (
        SELECT f.filename,
               COUNT(DISTINCT f.pr_number)                                  AS bug_prs,
               SUM(CASE WHEN b.state = 'open' THEN 1 ELSE 0 END)           AS open_bug_prs
        FROM pr_files f JOIN bug_prs_all b ON f.pr_number = b.pr_number
        GROUP BY f.filename
    ),
    overall AS (
        SELECT COUNT(DISTINCT p.number) AS total_prs,
               COUNT(DISTINCT b.pr_number) AS bug_pr_count
        FROM pull_requests p
        LEFT JOIN (SELECT DISTINCT pr_number FROM pr_labels WHERE label_name='bug') b
               ON p.number = b.pr_number
    )
    SELECT
        ft.filename,
        ft.top_dir,
        regexp_extract(ft.filename, '[^/]+$')                               AS basename,
        ft.total_prs,
        COALESCE(fb.bug_prs, 0)       AS bug_prs,
        COALESCE(fb.open_bug_prs, 0)  AS open_bug_prs,
        ROUND(100.0 * COALESCE(fb.bug_prs, 0) / ft.total_prs, 1)          AS bug_rate_pct,
        ROUND(
            (COALESCE(fb.bug_prs, 0)::DOUBLE / o.bug_pr_count) /
            (ft.total_prs::DOUBLE / o.total_prs), 2
        )                                                                   AS lift
    FROM file_totals ft
    CROSS JOIN overall o
    LEFT JOIN file_bugs fb ON ft.filename = fb.filename
    WHERE ft.total_prs >= 15
      AND ft.filename NOT LIKE 'doc/%'
      AND ft.filename NOT LIKE 'thirdparty/%'
      AND ft.filename != 'SConstruct'
      AND COALESCE(fb.bug_prs, 0) > 0
    ORDER BY bug_prs DESC
""").df()

DIR_COLORS = {
    "editor": BLUE, "scene": GREEN, "modules": ORANGE,
    "servers": PURPLE, "platform": RED, "drivers": CYAN,
    "core": YELLOW,
}
file_bug_df["dir_color"] = file_bug_df["top_dir"].map(DIR_COLORS).fillna(MUTED)
file_bug_df["marker_size"] = (file_bug_df["open_bug_prs"].clip(1) ** 0.55 * 5).clip(7, 42)

# ── 17. Bug-Prone File Scatter ─────────────────────────────────────────────────

ANNOTATE_FILES = set(
    file_bug_df[
        (file_bug_df["bug_prs"] >= 90) |
        (file_bug_df["lift"] >= 1.2) |
        (file_bug_df["open_bug_prs"] >= 28)
    ]["filename"]
)

fig17 = go.Figure()
for top_dir, color in {**DIR_COLORS, "other": MUTED}.items():
    if top_dir == "other":
        mask = ~file_bug_df["top_dir"].isin(DIR_COLORS)
    else:
        mask = file_bug_df["top_dir"] == top_dir
    sub = file_bug_df[mask]
    fig17.add_trace(go.Scatter(
        x=sub["bug_prs"], y=sub["lift"],
        mode="markers", name=top_dir + "/",
        marker=dict(color=color, size=sub["marker_size"],
                    opacity=0.82, line=dict(color=CARD, width=1.2)),
        customdata=list(zip(sub["filename"], sub["total_prs"],
                            sub["open_bug_prs"], sub["bug_rate_pct"])),
        hovertemplate=(
            "<b>%{customdata[0]}</b><br>"
            "Bug PRs: %{x}  |  Lift: %{y:.2f}×<br>"
            "Open bug PRs: %{customdata[2]}<br>"
            "Bug rate: %{customdata[3]}%  of  %{customdata[1]} total PRs"
            "<extra></extra>"
        ),
    ))

ann17 = file_bug_df[file_bug_df["filename"].isin(ANNOTATE_FILES)]
fig17.add_trace(go.Scatter(
    x=ann17["bug_prs"], y=ann17["lift"],
    mode="text",
    text=ann17["basename"],
    textposition="top right",
    textfont=dict(size=8, color=TEXT),
    showlegend=False,
    hoverinfo="skip",
))

# Quadrant shading regions
median_bugs = float(file_bug_df["bug_prs"].median())
fig17.add_vline(x=median_bugs, line_color=BORDER, line_dash="dot", line_width=1)
fig17.add_hline(y=1.0, line_color=MUTED, line_dash="dash", line_width=1.5,
                annotation_text="lift = 1.0  (baseline)", annotation_position="right",
                annotation_font=dict(color=MUTED, size=9))
for txt, x, y in [
    ("Bug Hotspots ↗", 0.97, 0.97),
    ("Busy but Expected ↘", 0.97, 0.03),
]:
    fig17.add_annotation(
        xref="paper", yref="paper", x=x, y=y, text=f"<i>{txt}</i>",
        showarrow=False, font=dict(color=MUTED, size=10),
        xanchor="right" if x > 0.5 else "left",
        yanchor="top" if y > 0.5 else "bottom",
    )

fig17.update_layout(**base_layout(
    t=100,
    title=dict(text="File Bug Proneness — Volume vs. Lift  (bubble = open bug backlog)", font=dict(size=16, color=TEXT), x=0),
    xaxis=dict(type="log", gridcolor=BORDER, title="Total bug PRs touching this file (log scale)"),
    yaxis=dict(gridcolor=BORDER, title="Lift  (×baseline)", range=[0.3, 1.65]),
    legend=dict(orientation="h", x=0, y=1.13, bgcolor="rgba(0,0,0,0)", font=dict(size=11)),
    hovermode="closest",
))

# ── 18. Bug Hotspot Treemap ────────────────────────────────────────────────────

treemap_df = file_bug_df.nlargest(60, "bug_prs").copy()
treemap_df["label_text"] = treemap_df["basename"] + "<br>" + treemap_df["lift"].map(lambda x: f"{x:.2f}×")

fig18 = px.treemap(
    treemap_df,
    path=["top_dir", "basename"],
    values="bug_prs",
    color="lift",
    color_continuous_scale=[[0, "#1a3a6c"], [0.4, BLUE], [0.65, YELLOW], [0.85, ORANGE], [1, RED]],
    range_color=[0.5, 1.5],
    custom_data=["filename", "open_bug_prs", "bug_rate_pct", "lift"],
)
fig18.update_traces(
    textfont=dict(color="white", size=11),
    hovertemplate=(
        "<b>%{customdata[0]}</b><br>"
        "Bug PRs: %{value}<br>"
        "Lift: %{customdata[3]:.2f}×<br>"
        "Open bug PRs: %{customdata[1]}<br>"
        "Bug rate: %{customdata[2]}%"
        "<extra></extra>"
    ),
)
fig18.update_layout(**base_layout(
    t=80,
    title=dict(text="Bug Hotspot Map — Top 60 Files  (size = bug PRs, color = lift)", font=dict(size=16, color=TEXT), x=0),
    coloraxis_colorbar=dict(
        title="Lift", tickvals=[0.5, 0.75, 1.0, 1.25, 1.5],
        ticktext=["0.5×","0.75×","1.0×","1.25×","1.5×"],
        tickfont=dict(color=TEXT), title_font=dict(color=TEXT),
        bgcolor=CARD, bordercolor=BORDER,
    ),
    height=680,
))

